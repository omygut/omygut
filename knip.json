{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/app.ts",
    "src/app.config.ts",
    "src/pages/**/index.tsx",
    "src/pages/**/index.config.ts",
    "config/index.ts"
  ],
  "project": ["src/**/*.{ts,tsx}", "config/**/*.ts", "scripts/**/*.ts"],
  "ignoreDependencies": [
    "@babel/runtime",
    "@tarojs/plugin-*",
    "@tarojs/react",
    "@tarojs/runtime",
    "@tarojs/vite-runner",
    "@vitejs/plugin-react",
    "miniprogram-ci",
    "picocolors",
    "tsx",
    "vite"
  ],
  "ignoreExportsUsedInFile": true,
  "ignore": ["src/types/index.ts", "scripts/test-ai-models.ts"],
  "ignoreBinaries": ["miniprogram-ci", "tsx"]
}
